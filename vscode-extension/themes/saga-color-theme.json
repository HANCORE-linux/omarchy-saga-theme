  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#9094A2", "fontStyle": "italic" }
    },
    {
      "name": "Strings",
      "scope": ["string", "string.quoted", "string.template", "punctuation.definition.string"],
      "settings": { "foreground": "#BAF7B5" }
    },
    {
      "name": "Numbers and Constants",
      "scope": ["constant.numeric", "constant.language", "constant.character", "constant.other", "support.constant"],
      "settings": { "foreground": "#FFC79B" }
    },
    {
      "name": "Keywords",
      "scope": ["keyword", "storage.modifier", "keyword.operator.new", "keyword.operator.expression", "keyword.control", "keyword.control.flow", "keyword.control.import"],
      "settings": { "foreground": "#FF9FBC" }
    },
    {
      "name": "Types",
      "scope": ["storage.type", "keyword.type", "entity.name.type", "entity.name.class", "support.type", "support.class"],
      "settings": { "foreground": "#FFF6C3" }
    },
    {
      "name": "Functions",
      "scope": ["entity.name.function", "support.function", "meta.function-call", "variable.function", "keyword.other.special-method"],
      "settings": { "foreground": "#9AB4F9" }
    },
    {
      "name": "Variables",
      "scope": ["variable", "meta.definition.variable.name", "support.variable", "variable.other"],
      "settings": { "foreground": "#F3CEFF" }
    },
    {
      "name": "Properties and Parameters",
      "scope": ["variable.parameter", "variable.other.member", "meta.object-literal.key", "support.variable.property", "entity.name.variable.field"],
      "settings": { "foreground": "#B2FFF3" }
    },
    {
      "name": "Tags",
      "scope": ["entity.name.tag", "punctuation.definition.tag", "meta.tag"],
      "settings": { "foreground": "#FF9FBC" }
    },
    {
      "name": "Attributes",
      "scope": ["entity.other.attribute-name", "text.html.basic entity.other.attribute-name"],
      "settings": { "foreground": "#FFC79B" }
    },
    {
      "name": "Operators and Punctuation",
      "scope": ["keyword.operator", "punctuation", "meta.brace", "meta.delimiter"],
      "settings": { "foreground": "#FFE1E1" }
    },
    {
      "name": "Namespaces",
      "scope": ["entity.name.namespace", "entity.name.module", "support.other.namespace"],
      "settings": { "foreground": "#DFBAFF" }
    },
    {
      "name": "Regex and Escapes",
      "scope": ["constant.character.escape", "string.regexp"],
      "settings": { "foreground": "#B2FFF3" }
    },
    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#FF9FBC" }
    },
    {
      "name": "Deprecated",
      "scope": ["invalid.deprecated"],
      "settings": { "foreground": "#B572EF", "fontStyle": "strikethrough" }
    },
    {
      "name": "Markdown",
      "scope": ["markup.heading", "markdown.heading", "markup.bold"],
      "settings": { "foreground": "#FFF6C3", "fontStyle": "bold" }
    },
    {
      "name": "Markdown Links",
      "scope": ["string.other.link", "constant.other.reference.link.markdown"],
      "settings": { "foreground": "#B2FFF3", "fontStyle": "underline" }
    },
    {
      "name": "Diff Inserted",
      "scope": ["markup.inserted"],
      "settings": { "foreground": "#BAF7B5" }
    },
    {
      "name": "Diff Deleted",
      "scope": ["markup.deleted"],
      "settings": { "foreground": "#FF9FBC" }
    },
    {
      "name": "Diff Changed",
      "scope": ["markup.changed"],
      "settings": { "foreground": "#B2FFF3" }
    }
  ]
}
